ANYTHINGLLM_API_KEY=your_api_key_here
ANYTHINGLLM_API_URL=http://localhost:3001/api/v1
ANYTHINGLLM_WORKSPACE_SLUG=your-workspace-slug

TESTER_NAME="your name for the output file"
KALI_VM_NAME="your kali vm name"
KALI_IP=your_kali_ip_address

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

METASPLOITABLE_VM_NAME="your metasploitable vm name"
METASPLOITABLE_IP=your_metasploitable_ip

DB_HOST=your_session_pooler_connection
DB_PORT=5432
DB_USER=your_user_connection
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SSLMODE=prefer

MCP_START_COMMAND=/your/path/to/redstack-vault/.mcp-server/start.sh