# PLANTE Environment Configuration Template
# Copy this file to .env and fill in your values

# ==============================================================================
# VM IP Addresses
# ==============================================================================
KALI_IP=192.168.56.101
METASPLOITABLE_IP=192.168.56.100
KALI_VM_NAME=kali-linux-2025.4-virtualbox-amd64
METASPLOITABLE_VM_NAME=Metasploitable2

# ==============================================================================
# OpenRouter LLM Configuration
# Get your API key from: https://openrouter.ai/settings/keys
# Note: Requires credits (~$0.30-0.50 per full test run with Grok-4)
# ==============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ==============================================================================
# Output Configuration
# ==============================================================================
TESTER_NAME=YourName

# ==============================================================================
# Database Configuration — OPTIONAL (Supabase PostgreSQL)
# Only needed for Error Path RAG persistence (error_rag.py).
# If not set, ErrorRAG degrades gracefully and lessons are not persisted.
# Get connection details from: https://supabase.com/dashboard
# ==============================================================================
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_NAME=postgres
DB_SSLMODE=require
